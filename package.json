{
  "name": "difftray",
  "version": "0.0.9",
  "private": true,
  "description": "Local diff review tool",
  "author": "Marco Gomiero",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --stream build",
    "bench:performance": "pnpm --filter @difftray/desktop bench:performance",
    "check": "./ci.sh",
    "dev": "pnpm --filter @difftray/desktop dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "package": "pnpm build && electron-builder --config electron-builder.config.cjs --publish never",
    "package:dev": "DIFFTRAY_RELEASE_CHANNEL=dev pnpm package",
    "package:mac": "pnpm build && electron-builder --config electron-builder.config.cjs --mac --publish never",
    "package:mac:dev": "DIFFTRAY_RELEASE_CHANNEL=dev pnpm package:mac",
    "release": "./scripts/release.sh",
    "release:dev:mac": "./scripts/release.sh mac dev",
    "release:mac": "./scripts/release.sh mac",
    "release:setup-app-ids": "./scripts/setup-app-ids.sh",
    "release:setup-signing": "./scripts/setup-signing.sh",
    "release:upload": "./scripts/release-upload.sh",
    "test": "pnpm -r --stream test",
    "test:visual": "pnpm --filter @difftray/desktop test:visual",
    "typecheck": "pnpm -r --stream typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.21",
    "electron-builder": "^26.8.1",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
