{
  "name": "difftray",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --stream build",
    "check": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm test:visual",
    "dev": "pnpm --filter @difftray/desktop dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm -r --stream test",
    "test:visual": "pnpm --filter @difftray/desktop test:visual",
    "typecheck": "pnpm -r --stream typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
